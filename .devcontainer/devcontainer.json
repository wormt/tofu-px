{
  "name": "Terraform",
  "image": "mcr.microsoft.com/devcontainers/base:trixie",
  "features": {
    "ghcr.io/devcontainers/features/terraform:1": {}
  },
  "runArgs": [
    "--userns=keep-id"
  ],
  "containerUser": "vscode",
  "updateRemoteUserUID": false,
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform",
        "hashicorp.hcl"
      ]
    }
  }
}
